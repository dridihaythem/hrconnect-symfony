<!DOCTYPE html>
<html lang="en">

	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=0">
		<title>StarGame - Register</title>
		<link rel="shortcut icon" href="assets/img/favicon.png">
		<link rel="stylesheet" href="{{ asset('LoginStyle/assets/css/style.css') }}">
		<link rel="stylesheet" href="{{ asset('LoginStyle/assets/plugins/fontawesome/css/all.min.css') }}">
		<link rel="stylesheet" href="{{ asset('LoginStyle/assets/plugins/fontawesome/css/fontawesome.min.css') }}">
		<link rel="stylesheet" href="{{ asset('LoginStyle/assets/css/bootstrap.min.css') }}">
	</head>

	<body>
		<div class="main-wrapper login-body">
			<div class="login-wrapper">
				<div class="container">
					<img class="img-fluid logo-dark mb-2" src="{{ asset('assets/img/logo.png')}}" alt="Logo">
					<div class="loginbox">
						<div class="login-right">
							<div class="login-right-wrap">
								<h1>Register</h1>
								<p class="account-subtitle">Access to our dashboard</p>
								<form enctype="multipart/form-data" method="POST">
                                {{ form_start(form) }}
									<div class="form-group">
										{{form_row(form.cin)}}
									</div>
                                    <div class="row">
										<div class="col-xl-6 col-sm-12 col-12 ">
											<div class="form-group">
												{{form_row(form.nom)}}
											</div>
										</div>
										<div class="col-xl-6 col-sm-12 col-12 ">
											<div class="form-group">
												{{form_row(form.prenom)}}
											</div>
										</div>
									</div>
									<div class="form-group">
										{{form_row(form.tel)}}
									</div>
									<div class="form-group">
										{{form_row(form.email)}}
									</div>
									<div class="form-group">
										{{form_row(form.password)}}
									</div>
									<div class="form-group">
										<div class="row">
											<div class="col-6">
												<div class="custom-control custom-checkbox">
													<input type="checkbox" class="custom-control-input" id="cb1">
													<label class="custom-control-label" for="cb1">Remember me</label>
												</div>
											</div>
											<div class="col-6 text-right">
												<a class="forgot-link" href="forgot-password.html">Forgot Password ?</a>
											</div>
										</div>
									</div>
									<button class="btn btn-lg btn-block btn-primary" type="submit" >Register</button>
								{{ form_end(form) }}
									<div class="text-center dont-have">you have an account?
										<a href="{{ path('app_login') }}">Login</a>
									</div>
								</form>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
